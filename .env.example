# Vigorys Nuclear Edition Configuration

# LLM Configuration
LLM_PROVIDER=grok
LLM_API_KEY=your_api_key_here
LLM_MODEL=grok-2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Crawling Configuration
MAX_PAGES=100
MAX_FORMS=50
CRAWL_TIMEOUT=300
USER_AGENT=Vigorys/2.0

# Scanning Configuration
SCAN_MODE=nuclear
PARALLEL_WORKERS=4
ENABLE_FUZZING=true
ENABLE_RACE_CONDITIONS=true

# Business Rules
CUSTOM_RULES_FILE=business_rules.yaml

# Output Configuration
VERBOSE=false
LOG_FILE=vigorys.log
EXPORT_FORMAT=json

# Demo Mode
DEMO_MODE=false
DEMO_TARGET=https://demo.vulnerable-app.local
